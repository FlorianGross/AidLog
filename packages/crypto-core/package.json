    "lint": "eslint src"
  },
  "dependencies": {
    "@aidlog/contracts": "workspace:*",
    "libsodium-wrappers-sumo": "^0.7.15"
  },
  "devDependencies": {
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "vitest": "^3.2.6"
