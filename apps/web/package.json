{
  "name": "@aidlog/web",
  "version": "0.1.0",
  "description": "Aidlog PWA: offline-first, zero-knowledge client. Renders configurable protocol forms, encrypts on-device, and syncs only ciphertext. Vendor-neutral.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@aidlog/contracts": "workspace:*",
    "@aidlog/crypto-core": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.4",
    "@types/node": "^25.9.3",
    "@vite-pwa/sveltekit": "^0.6.7",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.0",
    "vitest": "^3.2.6",
    "workbox-precaching": "^7.4.1"
  }
}
