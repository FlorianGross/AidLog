# Aidlog API configuration. Copy to `.env` and fill in. NEVER commit a real .env.
# The server only holds INFRASTRUCTURE credentials here — never any org/helper
# password, DEK, or unwrapped secret key.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Postgres. The application MUST connect as the least-privilege `aidlog_app`
# role (created by the migration) which has only INSERT/SELECT on `records`.
DATABASE_URL=postgres://aidlog_app:change-me@localhost:5432/aidlog
# Run migrations as the database OWNER (privileged), not as aidlog_app:
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/aidlog

# CORS: comma-separated origins, or * for any (dev only).
CORS_ORIGIN=*

# Session token HMAC key. Use a long random value in production.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_SECONDS=28800
CHALLENGE_TTL_SECONDS=120

# MinIO / S3-compatible object storage for opaque blob ciphertext.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aidlog-blobs
S3_FORCE_PATH_STYLE=true
BLOB_TICKET_TTL_SECONDS=300
BLOB_MAX_BYTES=26214400

RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
LOG_LEVEL=info
