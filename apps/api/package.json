{
  "name": "@aidlog/api",
  "version": "0.1.0",
  "description": "Aidlog server: a BLIND append-only sync + blob store. Stores ciphertext + routing metadata only; never sees plaintext, DEKs, passwords or unwrapped secret keys.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint handled at root\" && exit 0"
  },
  "dependencies": {
    "@aidlog/contracts": "workspace:*",
    "@aidlog/crypto-core": "workspace:*",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "pino": "^9.4.0",
    "postgres": "^3.4.4",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^3.2.6"
  }
}
