# ============================================================================
# Aidlog self-hosting environment. Copy to `infra/.env` and fill in REAL values.
#
#   cp infra/.env.example infra/.env
#
# ⚠️  GENERATE STRONG, UNIQUE SECRETS for every *_PASSWORD / *_SECRET / *_KEY
#     below. Do NOT reuse the placeholders. Suggested generator (Linux/macOS):
#
#         openssl rand -base64 36
#
#     NEVER commit infra/.env (it is git-ignored). These are INFRASTRUCTURE
#     credentials only — the server never holds org/helper passwords, DEKs, or
#     unwrapped secret keys (that's the whole point: the server is a blind store).
# ============================================================================

# ---------------------------------------------------------------------------
# Public site / TLS (Caddy)
# ---------------------------------------------------------------------------
# The public domain that resolves (A/AAAA) to this host. Caddy gets a real
# Let's Encrypt cert for it automatically. Use "localhost" for local testing
# (Caddy then issues an internal self-signed cert).
AIDLOG_DOMAIN=aidlog.example.org
# Email for the ACME/Let's Encrypt account (expiry notices). Required for a
# real public cert; ignored for localhost.
ACME_EMAIL=ops@example.org

# ---------------------------------------------------------------------------
# CORS (api). Because web + api share an origin behind Caddy, set this to your
# public origin. Use "*" ONLY for throwaway local testing.
# ---------------------------------------------------------------------------
CORS_ORIGIN=https://aidlog.example.org

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Superuser / database OWNER. Used ONLY by the one-shot `migrate` service to run
# migrations (which create the append-only trigger + least-privilege role).
POSTGRES_USER=aidlog_owner
POSTGRES_PASSWORD=CHANGE_ME_postgres_owner_password   # openssl rand -base64 36
POSTGRES_DB=aidlog

# Password for the LEAST-PRIVILEGE application role `aidlog_app` (INSERT/SELECT
# on records only). The running api connects with this — never the superuser.
AIDLOG_APP_DB_PASSWORD=CHANGE_ME_app_role_password    # openssl rand -base64 36

# ---------------------------------------------------------------------------
# MinIO / S3 object storage (opaque blob ciphertext)
# ---------------------------------------------------------------------------
# MinIO root credentials. The api uses these as its S3 access/secret key.
# (For tighter least-privilege, create a scoped MinIO service account limited to
# the bucket and use that instead — see infra/README.md hardening checklist.)
MINIO_ROOT_USER=aidlog_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password          # openssl rand -base64 36
# Bucket that holds blob ciphertext. Created automatically by `minio-setup`.
S3_BUCKET=aidlog-blobs
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# API security / behaviour
# ---------------------------------------------------------------------------
# HMAC key for tamper-evident session tokens. MUST be long + random (>=16 chars;
# use 32+). Rotating it invalidates all existing sessions.
SESSION_SECRET=CHANGE_ME_long_random_session_secret   # openssl rand -base64 36
SESSION_TTL_SECONDS=28800        # 8h session lifetime
CHALLENGE_TTL_SECONDS=120        # auth challenge lifetime

BLOB_TICKET_TTL_SECONDS=300      # presigned upload URL lifetime
BLOB_MAX_BYTES=26214400          # 25 MiB max direct-upload body

# Rate limiting (api already enforces this via @fastify/rate-limit).
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# STRICTER per-route limit for brute-forceable endpoints (auth challenge/verify
# and invitation redeem), applied on top of the global limit above to throttle
# proof-of-possession / invitation-code guessing per IP. Optional — sensible
# defaults apply if unset. Uncomment to override.
# AUTH_RATE_LIMIT_MAX=10
# AUTH_RATE_LIMIT_WINDOW=1 minute

# Log verbosity: fatal|error|warn|info|debug|trace|silent. Keep at info or
# higher in production for GDPR data-minimisation (debug may be noisier).
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Web push (VAPID) — OPTIONAL. Enables operational/administrative push
# notifications (e.g. "a co-signature was requested"). Payloads are GENERIC and
# CONTENT-FREE — never patient data, record content, or names.
#
# Leave ALL THREE blank to DISABLE push gracefully (the endpoints then report
# "not configured" and nothing else breaks). To enable, generate a keypair:
#
#         npx web-push generate-vapid-keys
#
# Then paste the public/private keys below. These keys only AUTHENTICATE this
# server to the browser push service (VAPID JWT); they CANNOT decrypt any Aidlog
# content. Still: treat the PRIVATE key as a secret and never commit a real one.
# VAPID_SUBJECT must be a mailto: or https: contact URL (RFC 8292).
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.org

# ---------------------------------------------------------------------------
# Archival anchoring (tamper-evident Merkle anchor over the record hash-chain).
#
# The server builds a deterministic Merkle tree over the org's PUBLIC record
# hashes (recordHash/seq/deploymentId — integrity metadata it already stores) and
# signs the root. NOTHING is decrypted; no patient data is touched.
#
# ANCHOR_SECRET signs the anchor root (HMAC-SHA256). It is NOT a content key and
# cannot decrypt anything. OPTIONAL: if blank, the server derives a dedicated key
# from SESSION_SECRET (domain-separated), so anchoring works out of the box. Set a
# distinct value to decouple anchor-signing from session tokens. >=16 chars.
ANCHOR_SECRET=
# OPTIONAL RFC 3161 Time-Stamping Authority. When set, a new anchor ALSO obtains a
# trusted timestamp over its root and stores the token; when blank, anchoring
# degrades gracefully to a baseline server-signed anchor. A TSA failure NEVER
# blocks anchoring. Example public TSA: https://freetsa.org/tsr
TSA_URL=
TSA_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# WORM hardening (Write-Once-Read-Many) — defence in depth for the archive.
#
# `records` is ALREADY append-only at the database layer: migration 0001 installs
# a BEFORE UPDATE/DELETE trigger that RAISES EXCEPTION, AND the app connects as the
# least-privilege `aidlog_app` role with INSERT/SELECT only (no UPDATE/DELETE).
# `notarization_anchors` and `audit_log` likewise get INSERT/SELECT only. This is
# the primary, always-on tamper-evidence guarantee.
#
# For object storage (encrypted blob ciphertext in MinIO/S3) you can OPTIONALLY add
# S3 Object Lock (WORM) so blob objects cannot be overwritten or deleted before a
# retention period elapses. This is NOT enabled by default (it requires a bucket
# created WITH object-lock and changes operational/lifecycle behaviour). See the
# commented guidance in infra/docker-compose.yml (minio-setup) and infra/README.md.
# Optional retention applied to the blob bucket when you opt in (e.g. "2555d" = 7y):
# S3_OBJECT_LOCK_RETENTION_DAYS=2555
